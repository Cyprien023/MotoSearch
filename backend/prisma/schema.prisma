generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Moto {
  id               String   @id @default(uuid())
  marque           String
  modele           String
  annee            Int
  kilometrage      Int
  prix             Float
  cylindree        Int
  puissance        Float
  type             String
  localisation     String
  region           String
  vendeur          String
  datePublication  DateTime
  photoUrl         String
  distanceKm       Float
  createdAt        DateTime @default(now())
  favoris          Favori[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  favoris   Favori[]
}

model Favori {
  id        String   @id @default(uuid())
  userId    String
  motoId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moto      Moto     @relation(fields: [motoId], references: [id], onDelete: Cascade)

  @@unique([userId, motoId])
}