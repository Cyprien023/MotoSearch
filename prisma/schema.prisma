generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Moto {
  id               String   @id @default(uuid())
  marque           String
  modele           String
  annee            Int
  kilometrage      Int
  prix             Float
  cylindree        Int
  puissance        Float
  type             String
  localisation     String
  region           String
  vendeur          String
  datePublication  DateTime
  photoUrl         String
  distanceKm       Float
  createdAt        DateTime @default(now())
}
